# Her Ruby Landing Page — Environment Variables
# Copy this file to .env.local for local dev
# Add these as Environment Variables in your Vercel project dashboard

# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1...

# ── App URLs ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.herruby.ca

# ── Events ────────────────────────────────────────────────────────────
# Paste your Eventbrite event URL here (used on /pilot page register button)
NEXT_PUBLIC_EVENTBRITE_URL=https://www.eventbrite.ca/e/her-ruby-pilot-day

# ── Contact / Waitlist (optional integrations) ────────────────────────
# Formspree endpoint for contact form (sign up free at formspree.io)
NEXT_PUBLIC_FORMSPREE_ID=xrgvwxyz
# Mailchimp/ConvertKit API for waitlist (handled server-side via API route)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
